# ===== Claude (Anthropic) =====
# 종합 평가 생성에 사용. 미설정 시 규칙 기반 폴백 리포트로 동작
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 사용할 모델 (기본: claude-opus-4-20250514)
CLAUDE_MODEL=claude-opus-4-20250514

# 종합 평가 출력 토큰 한계 (기존 1000 → 상향). 길수록 비용↑, 응답 시간↑
CLAUDE_MAX_TOKENS=8000

# ===== Admin =====
# Admin 평가 콘솔(/admin) 접속 비밀번호. 운영 시 반드시 변경!
ADMIN_PASSWORD=change-this-password

# ===== 서버 =====
# Railway가 자동으로 PORT를 주입함. 로컬에서만 사용
PORT=3000

# SQLite 저장 경로. Railway Volume 마운트 경로로 지정 (예: /data/data.db)
DB_PATH=./data/data.db
